{
  "datasets": [
    {
      "name": "1595a58a",
      "displayName": "CPU Utilization by Hour",
      "queryLines": [
        "select\n",
        "  *,\n",
        "  hour(EventTime) as Hr\n",
        "from\n",
        "  IDENTIFIER(:cpu_utilization_table)\n",
        "where\n",
        "  (SystemIdle + SQLProcessUtilization) <= 100\n",
        "order by\n",
        "  EventTime"
      ],
      "parameters": [
        {
          "displayName": "cpu_utilization_table",
          "keyword": "cpu_utilization_table",
          "dataType": "STRING",
          "defaultSelection": {
            "values": {
              "dataType": "STRING",
              "values": [
                {
                  "value": "<CATALOG_NAME>.<SCHEMA_NAME>.cpu_utilization_table"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "87d22714",
      "displayName": "Profiled Databases",
      "queryLines": [
        "select\n",
        "  DbName as name,\n",
        "  round(currentSizeMb / 1024, 2) as size_gb\n",
        "from\n",
        "  IDENTIFIER(:db_sizes_table);"
      ],
      "parameters": [
        {
          "displayName": "db_sizes_table",
          "keyword": "db_sizes_table",
          "dataType": "STRING",
          "defaultSelection": {
            "values": {
              "dataType": "STRING",
              "values": [
                {
                  "value": "<CATALOG_NAME>.<SCHEMA_NAME>.db_sizes"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "7ee063cf",
      "displayName": "Query Metrics",
      "queryLines": [
        "select\n",
        "  *,\n",
        "  to_date(creation_time) as creation_date,\n",
        "  hour(creation_time) as creation_hr\n",
        "from\n",
        "  IDENTIFIER(:query_stats_table)"
      ],
      "parameters": [
        {
          "displayName": "query_stats_table",
          "keyword": "query_stats_table",
          "dataType": "STRING",
          "defaultSelection": {
            "values": {
              "dataType": "STRING",
              "values": [
                {
                  "value": "<CATALOG_NAME>.<SCHEMA_NAME>.query_stats"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "7c8de801",
      "displayName": "Query Session Metrics",
      "queryLines": [
        "WITH query_stats as (\n",
        "  select\n",
        "    *\n",
        "  from\n",
        "    IDENTIFIER(:query_stats_table)\n",
        "),\n",
        "sessions as (\n",
        "  select\n",
        "    *\n",
        "  from\n",
        "    IDENTIFIER(:sessions_table)\n",
        "),\n",
        "total_compute_time as (\n",
        "  select\n",
        "    sum(total_worker_time) as total_cpu_time\n",
        "  from\n",
        "    query_stats\n",
        "),\n",
        "workload_cpu_distribution as (\n",
        "  select\n",
        "    command_type workload_type,\n",
        "    round(sum(total_worker_time) / total_cpu_time, 1) as percent_cpu_time\n",
        "  from\n",
        "    query_stats join total_compute_time\n",
        "  group by\n",
        "    command_type,\n",
        "    total_cpu_time\n",
        ")\n",
        "select\n",
        "  program_name as stage1,\n",
        "  login_name as stage2,\n",
        "  db_name as stage3,\n",
        "  sum(cpu_time) as value\n",
        "from\n",
        "  sessions\n",
        "group by\n",
        "  1,\n",
        "  2,\n",
        "  3;"
      ],
      "parameters": [
        {
          "displayName": "query_stats_table",
          "keyword": "query_stats_table",
          "dataType": "STRING",
          "defaultSelection": {
            "values": {
              "dataType": "STRING",
              "values": [
                {
                  "value": "<CATALOG_NAME>.<SCHEMA_NAME>.query_stats"
                }
              ]
            }
          }
        },
        {
          "displayName": "sessions_table",
          "keyword": "sessions_table",
          "dataType": "STRING",
          "defaultSelection": {
            "values": {
              "dataType": "STRING",
              "values": [
                {
                  "value": "<CATALOG_NAME>.<SCHEMA_NAME>.sessions"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "579a75ee",
      "displayName": "System Info",
      "queryLines": [
        "WITH sys_info as (\n",
        "  select\n",
        "    *\n",
        "  from\n",
        "    IDENTIFIER(:sys_info_table)\n",
        ")\n",
        "select\n",
        "  'cpu_count' name,\n",
        "  cpu_count value\n",
        "from\n",
        "  sys_info\n",
        "UNION ALL\n",
        "select\n",
        "  'hyperthread_ratio' name,\n",
        "  hyperthread_ratio value\n",
        "from\n",
        "  sys_info\n",
        "UNION ALL\n",
        "select\n",
        "  'max_workers_count' name,\n",
        "  max_workers_count value\n",
        "from\n",
        "  sys_info\n",
        "UNION ALL\n",
        "select\n",
        "  'physical_memory_gb' name,\n",
        "  round(physical_memory_kb / 1024 / 1024, 1) value\n",
        "from\n",
        "  sys_info\n",
        "UNION ALL\n",
        "select\n",
        "  'physical_memory_gb' name,\n",
        "  round(physical_memory_kb / 1024 / 1024, 1) value\n",
        "from\n",
        "  sys_info\n",
        "UNION ALL\n",
        "select\n",
        "  'virtual_machine' name,\n",
        "  virtual_machine_type_desc value\n",
        "from\n",
        "  sys_info;"
      ],
      "parameters": [
        {
          "displayName": "sys_info_table",
          "keyword": "sys_info_table",
          "dataType": "STRING",
          "defaultSelection": {
            "values": {
              "dataType": "STRING",
              "values": [
                {
                  "value": "<CATALOG_NAME>.<SCHEMA_NAME>.sys_info"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "23e42e9f",
      "displayName": "Inventory Databases",
      "queryLines": [
        "select\n",
        "  db_id,\n",
        "  name as name,\n",
        "  to_date(create_date) as created_on\n",
        "from\n",
        "  IDENTIFIER(:databases_table)\n",
        "order by\n",
        "  created_on;"
      ],
      "parameters": [
        {
          "displayName": "databases_table",
          "keyword": "databases_table",
          "dataType": "STRING",
          "defaultSelection": {
            "values": {
              "dataType": "STRING",
              "values": [
                {
                  "value": "<CATALOG_NAME>.<SCHEMA_NAME>.databases"
                }
              ]
            }
          }
        }
      ]
    }
